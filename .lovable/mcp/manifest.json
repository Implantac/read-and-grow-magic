{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://arcuhqdiydlvekanychw.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "use-sistemas-erp-mcp",
      "version": "0.1.0",
      "title": "Use Sistemas ERP"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Quem sou eu",
        "description": "Retorna o usuário autenticado no ERP (id, email, client_id).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "search_products",
        "title": "Buscar produtos",
        "description": "Lista produtos do estoque do usuário. Filtra por termo (nome/SKU) e retorna até `limit` resultados. Respeita RLS multi-tenant.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Termo de busca por nome ou SKU."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 50,
              "description": "Máximo de resultados (padrão 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_payables",
        "title": "Contas a pagar",
        "description": "Lista títulos financeiros a pagar (accounts_payable). Filtra por status ('open', 'paid', 'overdue') e retorna até `limit` registros ordenados por vencimento.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "open",
                "paid",
                "overdue"
              ],
              "description": "Filtra pelo status do título."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "description": "Máximo de resultados (padrão 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
