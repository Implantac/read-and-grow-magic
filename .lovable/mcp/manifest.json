{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://arcuhqdiydlvekanychw.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "use-sistemas-erp-mcp",
      "version": "0.1.0",
      "title": "Use Sistemas ERP"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Quem sou eu",
        "description": "Retorna o usuário autenticado no ERP (id, email, client_id).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "search_products",
        "title": "Buscar produtos",
        "description": "Lista produtos do estoque do usuário. Filtra por termo (nome/SKU) e retorna até `limit` resultados. Respeita RLS multi-tenant.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Termo de busca por nome ou SKU."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 50,
              "description": "Máximo de resultados (padrão 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_payables",
        "title": "Contas a pagar",
        "description": "Lista títulos financeiros a pagar (accounts_payable). Filtra por status ('open', 'paid', 'overdue') e retorna até `limit` registros ordenados por vencimento.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "open",
                "paid",
                "overdue"
              ],
              "description": "Filtra pelo status do título."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "description": "Máximo de resultados (padrão 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_orders",
        "title": "Listar pedidos",
        "description": "Lista pedidos comerciais (orders) filtrando por status e intervalo de datas (campo `date`). Respeita RLS multi-tenant e retorna até `limit` registros ordenados por data desc.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "confirmed",
                "processing",
                "separated",
                "invoiced",
                "shipped",
                "delivered",
                "cancelled",
                "quote",
                "awaiting_commercial_approval",
                "awaiting_financial_approval",
                "blocked",
                "awaiting_separation",
                "in_separation",
                "awaiting_production",
                "in_production",
                "partial_production",
                "awaiting_conference",
                "conferenced",
                "awaiting_billing"
              ],
              "description": "Filtra pelo status do pedido."
            },
            "date_from": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Data inicial (YYYY-MM-DD), inclusive."
            },
            "date_to": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Data final (YYYY-MM-DD), inclusive."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "description": "Máximo de resultados (padrão 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_order",
        "title": "Buscar pedido por ID",
        "description": "Retorna um pedido comercial (orders) pelo `order_id` com seus itens (order_items). Respeita RLS multi-tenant — só retorna o pedido se o usuário tiver acesso.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "order_id": {
              "type": "string",
              "format": "uuid",
              "description": "UUID do pedido."
            }
          },
          "required": [
            "order_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
